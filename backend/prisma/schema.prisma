generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  STUDENT
  COLLEGE
  ADMIN
}

enum UserStatus {
  ACTIVE
  INACTIVE
}

enum DocumentStatus {
  PENDING
  VERIFIED
  REJECTED
}

enum ApplicationStatus {
  PENDING
  SHORTLISTED
  ACCEPTED
  REJECTED
}

enum ApplicationType {
  COLLEGE
  CERTIFICATION
}

enum PaymentStatus {
  NOT_READY
  PENDING
  PAID
  FAILED
}

enum InquiryStatus {
  NEW
  CONTACTED
  CONVERTED
  CLOSED
}

enum AppointmentMode {
  IN_PERSON
  CALL
  VIDEO
}

enum AppointmentStatus {
  REQUESTED
  CONFIRMED
  COMPLETED
  CANCELED
}

model User {
  id           String            @id @default(cuid())
  managedCollegeId String?
  name         String
  email        String            @unique
  passwordHash String
  phone        String?
  city         String?
  bio          String?
  avatarUrl    String?
  targetCourse String?
  role         UserRole          @default(STUDENT)
  status       UserStatus        @default(ACTIVE)
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt
  applications Application[]
  inquiries    Inquiry[]
  collegeReviews CollegeReview[]
  appointments Appointment[]
  offlineInquiries OfflineInquiry[]
  documents    UserDocument[]
  examAttempts MockExamAttempt[]
  chatMessages ChatMessage[]
  managedCollege College?        @relation("ManagedCollege", fields: [managedCollegeId], references: [id], onDelete: SetNull)
}

model College {
  id                   String        @id @default(cuid())
  name                 String
  location             String
  type                 String
  rank                 Int
  rating               Float
  feesPerYear          Int
  description          String
  website              String?
  phone                String?
  email                String?
  established          Int?
  admissionRequirements String[]
  createdAt            DateTime      @default(now())
  updatedAt            DateTime      @updatedAt
  courses              Course[]
  managers             User[]         @relation("ManagedCollege")
  applications         Application[]
  inquiries            Inquiry[]
  reviews              CollegeReview[]
  appointments         Appointment[]

  @@index([location])
  @@index([type])
  @@index([rank])
}

model Course {
  id          String   @id @default(cuid())
  collegeId   String
  name        String
  duration    String
  feesPerYear Int
  seats       Int
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  college     College  @relation(fields: [collegeId], references: [id], onDelete: Cascade)

  @@index([collegeId])
}

model Application {
  id                    String            @id @default(cuid())
  userId                String
  type                  ApplicationType   @default(COLLEGE)
  collegeId             String?
  certificationCourseId String?
  courseName            String?
  applicantName         String
  applicantEmail        String
  applicantPhone        String
  qualification         String
  scoreOrRank           String?
  statement             String?
  requirementsSnapshot  String[]
  paymentStatus         PaymentStatus      @default(NOT_READY)
  paymentAmount         Int?
  paymentOrderId        String?
  paymentReference      String?
  status                ApplicationStatus @default(PENDING)
  appliedAt             DateTime          @default(now())
  createdAt             DateTime          @default(now())
  updatedAt             DateTime          @updatedAt
  user                  User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  college               College?          @relation(fields: [collegeId], references: [id], onDelete: Cascade)
  certificationCourse   CertificationCourse? @relation(fields: [certificationCourseId], references: [id], onDelete: Cascade)
  documents             UserDocument[]

  @@index([userId])
  @@index([collegeId])
  @@index([certificationCourseId])
  @@index([type])
  @@index([status])
}

model Inquiry {
  id         String        @id @default(cuid())
  userId     String
  collegeId  String
  courseName String
  message    String
  status     InquiryStatus @default(NEW)
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt
  user       User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  college    College       @relation(fields: [collegeId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([collegeId])
  @@index([status])
}

model CollegeReview {
  id        String   @id @default(cuid())
  userId    String
  collegeId String
  rating    Int
  comment   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  college   College  @relation(fields: [collegeId], references: [id], onDelete: Cascade)

  @@unique([userId, collegeId])
  @@index([collegeId, createdAt])
}

model Appointment {
  id            String            @id @default(cuid())
  userId        String
  collegeId     String
  scheduledFor  DateTime
  mode          AppointmentMode
  notes         String?
  status        AppointmentStatus @default(REQUESTED)
  counselorName String?
  meetingLink   String?
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt
  user          User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  college       College           @relation(fields: [collegeId], references: [id], onDelete: Cascade)

  @@index([userId, scheduledFor])
  @@index([collegeId, scheduledFor])
  @@index([status])
}

model BlogPost {
  id          String   @id @default(cuid())
  title       String
  excerpt     String
  content     String
  externalUrl String?
  author      String
  category    String
  readTime    String
  publishedAt DateTime
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([category])
  @@index([publishedAt])
}

model ChatMessage {
  id        String   @id @default(cuid())
  userId     String
  role      String
  content   String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
}

model MockExamAttempt {
  id              String   @id @default(cuid())
  userId          String
  examType        String   @default("KCET")
  difficulty      String   @default("Medium")
  score           Int
  total           Int
  correctAnswers  Int      @default(0)
  incorrectAnswers Int     @default(0)
  duration        Int
  createdAt       DateTime @default(now())
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
}

model CareerRecommendation {
  id         String   @id @default(cuid())
  title      String
  salary     String
  demand     String
  matchScore Int
  skills     String[]
  createdAt  DateTime @default(now())
}

model CertificationCourse {
  id           String        @id @default(cuid())
  title        String
  provider     String
  duration     String
  enrolled     Int
  rating       Float
  level        String
  price        String
  description  String
  requirements String[]
  applications Application[]
  createdAt    DateTime      @default(now())
}

model MockQuestion {
  id          String   @id @default(cuid())
  examType    String   @default("KCET")
  difficulty  String   @default("Medium")
  question    String
  options     String[]
  answer      Int
  explanation String?
  createdAt   DateTime @default(now())
}

model RankCutoff {
  id        String   @id @default(cuid())
  year      Int      @unique
  cutoff    Int
  createdAt DateTime @default(now())
}

model SeatAllotmentTrend {
  id          String   @id @default(cuid())
  year        Int
  round       Int
  category    String
  collegeName String
  courseName  String
  cutoffRank  Int
  createdAt   DateTime @default(now())

  @@index([year, round, category])
}

model UserDocument {
  id            String         @id @default(cuid())
  userId        String
  applicationId String?
  title         String
  documentType  String
  fileName      String
  mimeType      String
  fileDataUrl   String
  status        DocumentStatus @default(PENDING)
  adminNotes    String?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  verifiedAt    DateTime?
  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  application   Application?   @relation(fields: [applicationId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([applicationId])
  @@index([status])
}

model OfflineInquiry {
  id           String   @id @default(cuid())
  userId       String
  topic        String
  preferredMode String
  message      String
  status       String   @default("OPEN")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
}

